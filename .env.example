# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_meeting_platform?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/ai_meeting_platform?schema=public"

# Redis (for BullMQ and caching)
REDIS_URL="redis://localhost:6379"

# Auth.js (NextAuth v5)
AUTH_SECRET="your-auth-secret-min-32-chars"
AUTH_URL="http://localhost:3000"

# OAuth providers
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# Email / SMTP (for magic link and notifications)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="noreply@example.com"

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET_NAME="ai-meeting-recordings"
AWS_S3_ENDPOINT=""

# AI providers
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="your-gemini-api-key"

# Realtime
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# Billing
STRIPE_PUBLISHABLE_KEY="pk_..."
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Monitoring
SENTRY_DSN="https://..."
SENTRY_AUTH_TOKEN="sntrys_..."
POSTHOG_KEY="phc_..."
POSTHOG_HOST="https://us.i.posthog.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
